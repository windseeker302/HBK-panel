HBK_SERVER_PORT=80
HBK_PUBLIC_CENTER_URL=http://your-server-ip
VITE_API_BASE_URL=/
HBK_REQUIRE_TLS=false
HBK_PYTHON_BASE_IMAGE=python:3.11-slim
HBK_NODE_BASE_IMAGE=node:20-alpine
HBK_NGINX_BASE_IMAGE=nginx:1.27-alpine

# 可选：把默认 demo 节点 token 固定到启动配置中。
# HBK_NODE_TOKENS_JSON={"node-a":"token-node-a-demo","node-b":"token-node-b-demo","node-c":"token-node-c-demo"}
